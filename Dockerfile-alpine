# syntax=docker/dockerfile:1.4

# Stage 1: Build and dependencies
FROM python:3.13.14-alpine AS foundation

# Upgrade xz to patch CVE-2026-34743 (heap buffer overflow in xz < 5.8.3-r0)
RUN apk add --no-cache --upgrade xz

# Install build deps
RUN apk add --no-cache \
    gcc \
    g++ \
    musl-dev \
    python3-dev \
    libffi-dev \
    postgresql-dev \
    freetds-dev \
    openblas-dev \
    lapack-dev \
    pkgconfig

WORKDIR /mlflow-build/

# Upgrade pip and install Poetry before copying project files so this layer
# is cached independently of poetry.lock changes
RUN python -m pip install --upgrade pip --no-cache-dir && \
    pip install poetry wheel poetry-plugin-export --no-cache-dir

# Copy only necessary files for dependency installation
COPY pyproject.toml poetry.toml poetry.lock LICENSE README.md ./
COPY mlflowstack ./mlflowstack

RUN --mount=type=cache,target=/root/.cache/pip \
    --mount=type=cache,target=/root/.cache/pypoetry \
    poetry build --format wheel --no-interaction

# Export pinned requirements from lock file so pip respects exact versions
RUN poetry export --without-hashes -o /tmp/requirements.txt

# Create venv, install locked deps first, then the wheel without re-resolving
RUN python -m venv /opt/venv
RUN --mount=type=cache,target=/root/.cache/pip \
    /opt/venv/bin/pip install --prefer-binary -r /tmp/requirements.txt && \
    /opt/venv/bin/pip install --prefer-binary --no-deps /mlflow-build/dist/mlflowstack-*.whl

# Stage 2: Final Runtime
FROM python:3.13.14-alpine

LABEL maintainer="Burak Ince <burak.ince@linux.org.tr>"

# Upgrade xz to patch CVE-2026-34743 (heap buffer overflow in xz < 5.8.3-r0)
RUN apk add --no-cache --upgrade xz

# Runtime deps
RUN apk add --no-cache \
    libstdc++ \
    libgomp \
    openblas \
    ca-certificates \
    libpq \
    freetds

# Create non-root user
RUN mkdir -p /mlflow/mlruns && \
    addgroup -g 1001 -S mlflow && \
    adduser -S -u 1001 -G mlflow mlflow && \
    chown -R mlflow:mlflow /mlflow

WORKDIR /mlflow

# Copy the virtual environment from the foundation stage and set ownership
COPY --from=foundation --chown=mlflow:mlflow /opt/venv /opt/venv

# Activate venv
ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1

# Switch to non-root user
USER mlflow

EXPOSE 5000

# Default command to run MLflow server
CMD ["mlflow", "server", "--backend-store-uri", "sqlite:///mlflow.sqlite", "--default-artifact-root", "./mlruns", "--host=0.0.0.0", "--port=5000"]
